{
  "name": "@majikah/majik-key",
  "type": "module",
  "description": "A post-quantum ready seed phrase account library for the Majikah ecosystem. Manages deterministic X25519 and ML-KEM-768 identities with Argon2id protection and seamless legacy account migration.",
  "version": "0.2.13",
  "license": "Apache-2.0",
  "author": "Zelijah",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Majikah/majik-key.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/jedlsf"
  },
  "keywords": [
    "seed-phrase",
    "mnemonic",
    "bip39",
    "crypto",
    "cryptography",
    "account",
    "key-generation",
    "deterministic",
    "seed",
    "keypair",
    "majik-key",
    "blockchain",
    "authentication",
    "security",
    "ed25519",
    "key-derivation"
  ],
  "homepage": "https://github.com/Majikah/majik-key#readme",
  "bugs": {
    "url": "https://github.com/Majikah/majik-key/issues"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "package": "npm run build && npm version patch && git push && git push --tags",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:web3:bitcoin": "npx vitest test/majik-key-bitcoin.test.ts",
    "test:web3:solana": "npx vitest test/majik-key-solana.test.ts",
    "test:web3": "npx vitest test/majik-key-bitcoin.test.ts test/majik-key-solana.test.ts",
    "test:core": "npx vitest test/majik-key.test.ts"
  },
  "dependencies": {
    "@majikah/majik-contact": "^0.0.6",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@noble/post-quantum": "^0.6.1",
    "@scure/bip32": "^2.2.0",
    "@scure/bip39": "^2.2.0",
    "@stablelib/aes": "^2.0.1",
    "@stablelib/ed25519": "^2.1.0",
    "@stablelib/gcm": "^2.0.1",
    "@stablelib/pbkdf2": "^2.0.1",
    "@stablelib/sha256": "^2.0.1",
    "@stablelib/x25519": "^2.0.1",
    "@thezelijah/majik-user": "^1.0.9",
    "ed2curve": "^0.3.0",
    "hash-wasm": "^4.12.0"
  },
  "devDependencies": {
    "@scure/btc-signer": "^2.2.0",
    "@solana/kit": "^7.0.0",
    "@types/ed2curve": "^0.2.4",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@scure/btc-signer": "^2.2.0",
    "@solana/kit": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@solana/kit": {
      "optional": true
    },
    "@scure/btc-signer": {
      "optional": true
    }
  }
}
